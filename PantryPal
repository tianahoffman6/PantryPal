<\u002Fdiv>\n        <select value=\"{{ groceryStoreFilter }}\" onchange=\"{{ onGroceryStoreFilter }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:9px 12px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n          <sc-for list=\"{{ storeFilterOptions }}\" as=\"opt\" hint-placeholder-count=\"4\">\n            <option value=\"{{ opt.value }}\">{{ opt.label }}<\u002Foption>\n          <\u002Fsc-for>\n        <\u002Fselect>\n        <button onclick=\"{{ toggleShowChecked }}\" style=\"{{ showCheckedToggleStyle }}\">{{ showCheckedLabel }}<\u002Fbutton>\n      <\u002Fdiv>\n      <div style=\"background:#fdfaf5;border-radius:14px;padding:12px 16px;margin-bottom:18px;display:flex;align-items:center;gap:10px;border:1px solid #e8ddd0;box-shadow:0 1px 3px rgba(44,31,14,.05);flex-wrap:wrap\">\n        <span style=\"font-size:22px\">{{ addGroceryCatEmoji }}<\u002Fspan>\n        <input placeholder=\"Add item… (auto-categorizes)\" value=\"{{ addGroceryName }}\" onchange=\"{{ onAddGroceryName }}\" onkeydown=\"{{ submitAddGrocery }}\" style=\"flex:1;min-width:140px;border:none;background:transparent;font-size:14px;color:#2c1f0e;font-weight:600\">\n        <span style=\"{{ addGroceryCatStyle }}\">{{ addGroceryCatLabel }}<\u002Fspan>\n        <input type=\"number\" min=\"1\" value=\"{{ addGroceryQty }}\" onchange=\"{{ onAddGroceryQty }}\" style=\"width:52px;border:1px solid #e8ddd0;border-radius:8px;padding:6px 8px;font-size:13px;text-align:center;background:#fdfaf5;font-weight:700\">\n        <select value=\"{{ addGroceryStore }}\" onchange=\"{{ onAddGroceryStore }}\" style=\"border:1px solid #e8ddd0;border-radius:8px;padding:6px 9px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n          <option value=\"Any\">Any store<\u002Foption>\n          <sc-for list=\"{{ storesList }}\" as=\"store\" hint-placeholder-count=\"3\">\n            <option value=\"{{ store }}\">{{ store }}<\u002Foption>\n          <\u002Fsc-for>\n        <\u002Fselect>\n        <button onclick=\"{{ submitAddGrocery }}\" style=\"background:#3a6e32;color:#fff;border:none;border-radius:10px;padding:8px 16px;font-size:13px;font-weight:800;cursor:pointer;white-space:nowrap\">Add<\u002Fbutton>\n      <\u002Fdiv>\n      <sc-if value=\"{{ hasChecked }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"text-align:right;margin-bottom:12px\">\n          <button onclick=\"{{ clearChecked }}\" style=\"font-size:12.5px;color:#a84a2a;background:none;border:none;cursor:pointer;font-weight:700\">Clear {{ checkedCount }} checked ×<\u002Fbutton>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ isGroceryCat }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"display:flex;flex-direction:column;gap:14px\">\n          <sc-for list=\"{{ groceryByCategory }}\" as=\"cat\" hint-placeholder-count=\"3\">\n            <div style=\"background:#fdfaf5;border-radius:14px;overflow:hidden;border:1px solid #e8ddd0;box-shadow:0 1px 3px rgba(44,31,14,.05)\">\n              <div style=\"{{ cat.catHeaderStyle }}\">\n                <span style=\"font-size:16px\">{{ cat.emoji }}<\u002Fspan>\n                <span style=\"{{ cat.catLabelStyle }}\">{{ cat.category }}<\u002Fspan>\n                <span style=\"font-size:12px;color:#b09a82;margin-left:auto\">{{ cat.unchecked }} left<\u002Fspan>\n              <\u002Fdiv>\n              <sc-for list=\"{{ cat.items }}\" as=\"item\" hint-placeholder-count=\"2\">\n                <div style=\"{{ item.rowStyle }}\">\n                  <div onclick=\"{{ item.toggle }}\" style=\"{{ item.checkStyle }}\">\n                    <sc-if value=\"{{ item.checked }}\" hint-placeholder-val=\"{{ false }}\">\n                      <span style=\"color:#fff;font-size:11px;font-weight:900\">✓<\u002Fspan>\n                    <\u002Fsc-if>\n                  <\u002Fdiv>\n                  <span style=\"{{ item.nameStyle }}\">{{ item.name }}<\u002Fspan>\n                  <div style=\"display:flex;align-items:center;gap:4px\">\n                    <button onclick=\"{{ item.decr }}\" style=\"{{ item.qtyBtnStyle }}\">−<\u002Fbutton>\n                    <span style=\"font-size:13px;font-weight:800;min-width:20px;text-align:center\">{{ item.qty }}<\u002Fspan>\n                    <button onclick=\"{{ item.incr }}\" style=\"{{ item.qtyBtnStyle }}\">+<\u002Fbutton>\n                  <\u002Fdiv>\n                  <select value=\"{{ item.store }}\" onchange=\"{{ item.setStore }}\" style=\"{{ item.storeSelectStyle }}\">\n                    <option value=\"Any\">Any<\u002Foption>\n                    <sc-for list=\"{{ storesList }}\" as=\"st\" hint-placeholder-count=\"3\">\n                      <option value=\"{{ st }}\">{{ st }}<\u002Foption>\n                    <\u002Fsc-for>\n                  <\u002Fselect>\n                  <button onclick=\"{{ item.del }}\" style=\"font-size:16px;background:none;border:none;cursor:pointer;color:#d4c4b0;padding:0 2px;line-height:1\">×<\u002Fbutton>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ isGroceryStore }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"display:flex;flex-direction:column;gap:14px\">\n          <sc-for list=\"{{ groceryByStore }}\" as=\"grpStore\" hint-placeholder-count=\"2\">\n            <div style=\"background:#fdfaf5;border-radius:14px;overflow:hidden;border:1px solid #e8ddd0;box-shadow:0 1px 3px rgba(44,31,14,.05)\">\n              <div style=\"{{ grpStore.storeHeaderStyle }}\">\n                <span style=\"font-size:15px;font-weight:800;color:#2c1f0e\">{{ grpStore.store }}<\u002Fspan>\n                <span style=\"{{ grpStore.storeBadgeStyle }}\">{{ grpStore.unchecked }} left<\u002Fspan>\n              <\u002Fdiv>\n              <sc-for list=\"{{ grpStore.items }}\" as=\"item\" hint-placeholder-count=\"2\">\n                <div style=\"{{ item.rowStyle }}\">\n                  <div onclick=\"{{ item.toggle }}\" style=\"{{ item.checkStyle }}\">\n                    <sc-if value=\"{{ item.checked }}\" hint-placeholder-val=\"{{ false }}\">\n                      <span style=\"color:#fff;font-size:11px;font-weight:900\">✓<\u002Fspan>\n                    <\u002Fsc-if>\n                  <\u002Fdiv>\n                  <span style=\"{{ item.nameStyle }}\">{{ item.name }}<\u002Fspan>\n                  <span style=\"{{ item.catLabelSmallStyle }}\">{{ item.category }}<\u002Fspan>\n                  <div style=\"display:flex;align-items:center;gap:4px;margin-left:auto\">\n                    <button onclick=\"{{ item.decr }}\" style=\"{{ item.qtyBtnStyle }}\">−<\u002Fbutton>\n                    <span style=\"font-size:13px;font-weight:800;min-width:20px;text-align:center\">{{ item.qty }}<\u002Fspan>\n                    <button onclick=\"{{ item.incr }}\" style=\"{{ item.qtyBtnStyle }}\">+<\u002Fbutton>\n                  <\u002Fdiv>\n                  <button onclick=\"{{ item.del }}\" style=\"font-size:16px;background:none;border:none;cursor:pointer;color:#d4c4b0;padding:0 2px;line-height:1\">×<\u002Fbutton>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n    <\u002Fsc-if>\n\n    <!-- ===== RECIPES ===== -->\n    <sc-if value=\"{{ isRecipes }}\" hint-placeholder-val=\"{{ false }}\">\n      <!-- Generator -->\n      <div style=\"background:#fdfaf5;border-radius:18px;padding:20px;border:1px solid #e8ddd0;box-shadow:0 1px 4px rgba(44,31,14,.06);margin-bottom:24px\">\n        <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#b09a82;margin-bottom:8px\">Meal<\u002Fdiv>\n        <div style=\"display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px\">\n          <sc-for list=\"{{ mealOptions }}\" as=\"opt\" hint-placeholder-count=\"4\">\n            <button style=\"{{ opt.style }}\" onclick=\"{{ opt.handler }}\">{{ opt.label }}<\u002Fbutton>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#b09a82;margin-bottom:8px\">Cuisine<\u002Fdiv>\n        <div style=\"display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px\">\n          <sc-for list=\"{{ cuisineOptions }}\" as=\"opt\" hint-placeholder-count=\"6\">\n            <button style=\"{{ opt.style }}\" onclick=\"{{ opt.handler }}\">{{ opt.label }}<\u002Fbutton>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"display:flex;flex-wrap:wrap;gap:20px;margin-bottom:14px\">\n          <div>\n            <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#b09a82;margin-bottom:8px\">Max time<\u002Fdiv>\n            <div style=\"display:flex;flex-wrap:wrap;gap:6px\">\n              <sc-for list=\"{{ timeOptions }}\" as=\"opt\" hint-placeholder-count=\"4\">\n                <button style=\"{{ opt.style }}\" onclick=\"{{ opt.handler }}\">{{ opt.label }}<\u002Fbutton>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#b09a82;margin-bottom:8px\">Spice<\u002Fdiv>\n            <div style=\"display:flex;flex-wrap:wrap;gap:6px\">\n              <sc-for list=\"{{ spiceOptions }}\" as=\"opt\" hint-placeholder-count=\"3\">\n                <button style=\"{{ opt.style }}\" onclick=\"{{ opt.handler }}\">{{ opt.label }}<\u002Fbutton>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#b09a82;margin-bottom:8px\">Serves<\u002Fdiv>\n            <div style=\"display:flex;flex-wrap:wrap;gap:6px\">\n              <sc-for list=\"{{ servingsOptions }}\" as=\"opt\" hint-placeholder-count=\"3\">\n                <button style=\"{{ opt.style }}\" onclick=\"{{ opt.handler }}\">{{ opt.label }}<\u002Fbutton>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"display:flex;flex-wrap:wrap;gap:8px;padding-top:14px;border-top:1px solid #f0e8dc\">\n          <button style=\"{{ inStockOnlyStyle }}\" onclick=\"{{ toggleInStockOnly }}\">✓ In stock only<\u002Fbutton>\n          <button style=\"{{ useExpiringStyle }}\" onclick=\"{{ toggleUseExpiring }}\">⏰ Use expiring first<\u002Fbutton>\n        <\u002Fdiv>\n        <button onclick=\"{{ generateRecipes }}\" style=\"width:100%;margin-top:18px;background:#2c1f0e;color:#e8d5b8;border:none;border-radius:13px;padding:15px;font-size:15px;font-weight:900;cursor:pointer\">✦ Generate recipes<\u002Fbutton>\n      <\u002Fdiv>\n\n      <sc-if value=\"{{ recipesLoading }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"text-align:center;padding:40px 20px;color:#b09a82\">\n          <div style=\"width:32px;height:32px;border:3px solid #e8ddd0;border-top-color:#3a6e32;border-radius:50%;animation:spin .9s linear infinite;margin:0 auto 14px\"><\u002Fdiv>\n          <div style=\"font-size:14px;font-weight:700\">Checking your pantry…<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ hasRecipesError }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"background:#fde8d8;border-radius:12px;padding:14px 18px;color:#a84a2a;font-size:13.5px;margin-bottom:16px;font-weight:600;border:1px solid #e8c8b0\">⚠ {{ recipesError }}<\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ hasRecipes }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"display:flex;flex-direction:column;gap:14px;margin-bottom:24px\">\n          <sc-for list=\"{{ enrichedRecipes }}\" as=\"recipe\" hint-placeholder-count=\"3\">\n            <div style=\"background:#fdfaf5;border-radius:18px;padding:20px;border:1px solid #e8ddd0;box-shadow:0 1px 4px rgba(44,31,14,.06);animation:fadeUp .3s ease both\">\n              <div style=\"display:flex;align-items:flex-start;gap:12px;margin-bottom:10px\">\n                <div style=\"flex:1\">\n                  <div style=\"font-family:'Bitter',Georgia,serif;font-size:20px;font-weight:700;line-height:1.2;margin-bottom:7px;color:#2c1f0e\">{{ recipe.title }}<\u002Fdiv>\n                  <div style=\"display:flex;flex-wrap:wrap;gap:6px\">\n                    <span style=\"font-size:12px;background:#f4ede2;color:#7a5f44;padding:3px 9px;border-radius:16px;font-weight:600\">⏱ {{ recipe.time }} min<\u002Fspan>\n                    <span style=\"font-size:12px;background:#f4ede2;color:#7a5f44;padding:3px 9px;border-radius:16px;font-weight:600\">👥 {{ recipe.serves }}<\u002Fspan>\n                    <span style=\"font-size:12px;background:#f4ede2;color:#7a5f44;padding:3px 9px;border-radius:16px;font-weight:600\">🌍 {{ recipe.cuisine }}<\u002Fspan>\n                    <span style=\"font-size:12px;background:#f4ede2;color:#7a5f44;padding:3px 9px;border-radius:16px;font-weight:600\">🌶 {{ recipe.spice }}<\u002Fspan>\n                  <\u002Fdiv>\n                <\u002Fdiv>\n                <button onclick=\"{{ recipe.saveToggle }}\" style=\"{{ recipe.saveButtonStyle }}\">{{ recipe.saveIcon }}<\u002Fbutton>\n              <\u002Fdiv>\n              <sc-if value=\"{{ recipe.usesExpiring }}\" hint-placeholder-val=\"{{ false }}\">\n                <div style=\"background:#fef8f0;border:1px solid #e8d4b8;border-radius:10px;padding:8px 12px;font-size:12.5px;color:#9a7010;margin-bottom:10px;font-weight:700\">⏰ Uses {{ recipe.expiringItem }} — expiring soon!<\u002Fdiv>\n              <\u002Fsc-if>\n              <div style=\"font-size:13.5px;color:#5a4a3a;line-height:1.6;margin-bottom:12px\">{{ recipe.description }}<\u002Fdiv>\n              <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:#b09a82;margin-bottom:8px\">Ingredients<\u002Fdiv>\n              <div style=\"display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px\">\n                <sc-for list=\"{{ recipe.ingredientsList }}\" as=\"ing\" hint-placeholder-count=\"5\">\n                  <span style=\"{{ ing.chipStyle }}\">{{ ing.name }}<\u002Fspan>\n                <\u002Fsc-for>\n              <\u002Fdiv>\n              <sc-if value=\"{{ recipe.expanded }}\" hint-placeholder-val=\"{{ false }}\">\n                <div style=\"margin-bottom:14px\">\n                  <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:#b09a82;margin-bottom:8px\">Steps<\u002Fdiv>\n                  <sc-for list=\"{{ recipe.steps }}\" as=\"step\" hint-placeholder-count=\"4\">\n                    <div style=\"display:flex;gap:10px;padding:8px 0;border-bottom:1px solid #f4ede2\">\n                      <span style=\"font-size:12px;font-weight:800;color:#d4c4b0;width:20px;flex-shrink:0\">{{ step.num }}<\u002Fspan>\n                      <span style=\"font-size:13.5px;color:#3a2e22;line-height:1.5\">{{ step.text }}<\u002Fspan>\n                    <\u002Fdiv>\n                  <\u002Fsc-for>\n                <\u002Fdiv>\n              <\u002Fsc-if>\n              <div style=\"display:flex;flex-wrap:wrap;gap:8px\">\n                <button onclick=\"{{ recipe.toggleExpand }}\" style=\"font-size:12.5px;color:#7a5f44;background:#f4ede2;border:none;border-radius:9px;padding:8px 14px;cursor:pointer;font-weight:700\">{{ recipe.stepsLabel }}<\u002Fbutton>\n                <button onclick=\"{{ recipe.openCook }}\" style=\"font-size:13px;color:#fdfaf5;background:#2c1f0e;border:none;border-radius:9px;padding:8px 18px;cursor:pointer;font-weight:800\">🍳 Cook this<\u002Fbutton>\n                <sc-if value=\"{{ recipe.hasMissing }}\" hint-placeholder-val=\"{{ false }}\">\n                  <button onclick=\"{{ recipe.addMissing }}\" style=\"font-size:12.5px;color:#a84a2a;background:#fde8d8;border:1px solid #e8c8b0;border-radius:9px;padding:8px 14px;cursor:pointer;font-weight:700\">+ Add missing to list<\u002Fbutton>\n                <\u002Fsc-if>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <!-- ── COOKBOOK ── -->\n      <div style=\"border-top:1px solid #e8ddd0;padding-top:24px\">\n        <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap\">\n          <div style=\"flex:1\">\n            <div style=\"font-family:'Bitter',Georgia,serif;font-size:22px;font-weight:700\">📖 Cookbook<\u002Fdiv>\n            <div style=\"font-size:12.5px;color:#b09a82;margin-top:2px;font-weight:600\">{{ cbCount }} of {{ cbTotal }} recipes shown<\u002Fdiv>\n          <\u002Fdiv>\n          <button onclick=\"{{ openAddRecipe }}\" style=\"background:#f4ede2;color:#5a4030;border:none;border-radius:12px;padding:9px 16px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap\">+ Add recipe<\u002Fbutton>\n          <button onclick=\"{{ generateMoreCookbook }}\" style=\"background:#3a6e32;color:#fff;border:none;border-radius:12px;padding:9px 16px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap\">✦ Generate more<\u002Fbutton>\n        <\u002Fdiv>\n        <sc-if value=\"{{ cbGenerating }}\" hint-placeholder-val=\"{{ false }}\">\n          <div style=\"display:flex;align-items:center;gap:10px;color:#b09a82;font-size:13.5px;font-weight:600;margin-bottom:14px\">\n            <div style=\"width:18px;height:18px;border:2.5px solid #e8ddd0;border-top-color:#3a6e32;border-radius:50%;animation:spin .9s linear infinite;flex-shrink:0\"><\u002Fdiv>\n            Generating new recipes…\n          <\u002Fdiv>\n        <\u002Fsc-if>\n        <!-- Filters -->\n        <div style=\"display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap\">\n          <div style=\"flex:1;min-width:160px;display:flex;align-items:center;gap:8px;background:#fdfaf5;border:1px solid #e8ddd0;border-radius:12px;padding:8px 12px\">\n            <span style=\"color:#b09a82;font-size:14px\">🔍<\u002Fspan>\n            <input placeholder=\"Search cookbook…\" value=\"{{ cbSearch }}\" onchange=\"{{ onCbSearch }}\" style=\"flex:1;border:none;background:transparent;font-size:13.5px;color:#2c1f0e;font-weight:600\">\n          <\u002Fdiv>\n          <select value=\"{{ cbMeal }}\" onchange=\"{{ onCbMeal }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 11px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <option value=\"All\">All meals<\u002Foption>\n            <option value=\"Breakfast\">Breakfast<\u002Foption>\n            <option value=\"Lunch\">Lunch<\u002Foption>\n            <option value=\"Dinner\">Dinner<\u002Foption>\n            <option value=\"Snack\">Snack<\u002Foption>\n          <\u002Fselect>\n          <select value=\"{{ cbCuisine }}\" onchange=\"{{ onCbCuisine }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 11px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <sc-for list=\"{{ cbCuisineList }}\" as=\"cu\" hint-placeholder-count=\"8\">\n              <option value=\"{{ cu }}\">{{ cu }}<\u002Foption>\n            <\u002Fsc-for>\n          <\u002Fselect>\n          <select value=\"{{ cbTime }}\" onchange=\"{{ onCbTime }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 11px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <option value=\"All\">Any time<\u002Foption>\n            <option value=\"15\">≤ 15 min<\u002Foption>\n            <option value=\"30\">≤ 30 min<\u002Foption>\n            <option value=\"45\">≤ 45 min<\u002Foption>\n            <option value=\"60\">≤ 60 min<\u002Foption>\n          <\u002Fselect>\n          <select value=\"{{ cbSpice }}\" onchange=\"{{ onCbSpice }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 11px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <option value=\"All\">Any spice<\u002Foption>\n            <option value=\"Mild\">Mild<\u002Foption>\n            <option value=\"Medium\">Medium<\u002Foption>\n            <option value=\"Hot\">Hot 🌶<\u002Foption>\n          <\u002Fselect>\n        <\u002Fdiv>\n        <!-- Match key -->\n        <div style=\"display:flex;gap:14px;margin-bottom:16px;flex-wrap:wrap\">\n          <div style=\"display:flex;align-items:center;gap:5px;font-size:11.5px;color:#b09a82;font-weight:600\"><span style=\"width:9px;height:9px;border-radius:50%;background:#5a9040;flex-shrink:0\"><\u002Fspan>Ready to cook<\u002Fdiv>\n          <div style=\"display:flex;align-items:center;gap:5px;font-size:11.5px;color:#b09a82;font-weight:600\"><span style=\"width:9px;height:9px;border-radius:50%;background:#c07840;flex-shrink:0\"><\u002Fspan>Partial match<\u002Fdiv>\n          <div style=\"display:flex;align-items:center;gap:5px;font-size:11.5px;color:#b09a82;font-weight:600\"><span style=\"width:9px;height:9px;border-radius:50%;background:#b04068;flex-shrink:0\"><\u002Fspan>Need to shop<\u002Fdiv>\n        <\u002Fdiv>\n        <!-- Grid -->\n        <div style=\"display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px\">\n          <sc-for list=\"{{ cbRecipes }}\" as=\"recipe\" hint-placeholder-count=\"9\">\n            <div onclick=\"{{ recipe.open }}\" style=\"background:#fdfaf5;border-radius:14px;padding:14px 15px;border:1px solid #e8ddd0;cursor:pointer;display:flex;flex-direction:column;gap:8px;box-shadow:0 1px 3px rgba(44,31,14,.05)\">\n              <div style=\"display:flex;align-items:flex-start;gap:8px\">\n                <span style=\"width:10px;height:10px;border-radius:50%;background:{{ recipe.matchColor }};flex-shrink:0;margin-top:5px;display:inline-block\"><\u002Fspan>\n                <div style=\"flex:1;min-width:0\">\n                  <div style=\"font-size:14px;font-weight:700;color:#2c1f0e;line-height:1.25;margin-bottom:4px\">{{ recipe.title }}<\u002Fdiv>\n                  <div style=\"font-size:11.5px;color:#b09a82;font-weight:600\">{{ recipe.cuisine }} · {{ recipe.meal }}<\u002Fdiv>\n                <\u002Fdiv>\n              <\u002Fdiv>\n              <div style=\"font-size:12px;color:#7a5f44;line-height:1.45\">{{ recipe.description }}<\u002Fdiv>\n              <div style=\"display:flex;align-items:center;gap:6px;flex-wrap:wrap\">\n                <span style=\"font-size:11px;background:#f4ede2;color:#7a5f44;padding:2px 8px;border-radius:12px;font-weight:600\">⏱ {{ recipe.time }}m<\u002Fspan>\n                <span style=\"font-size:11px;background:#f4ede2;color:#7a5f44;padding:2px 8px;border-radius:12px;font-weight:600\">🌶 {{ recipe.spice }}<\u002Fspan>\n                <span style=\"font-size:10.5px;padding:2px 7px;border-radius:9px;background:{{ recipe.matchBg }};color:{{ recipe.matchColor }};font-weight:700;margin-left:auto\">{{ recipe.matchLabel }}<\u002Fspan>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <!-- Saved recipes -->\n      <sc-if value=\"{{ hasSaved }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"margin-top:30px\">\n          <div style=\"font-family:'Bitter',Georgia,serif;font-size:18px;font-weight:700;margin-bottom:12px\">♥ Saved recipes<\u002Fdiv>\n          <div style=\"display:flex;flex-direction:column;gap:8px\">\n            <sc-for list=\"{{ enrichedSaved }}\" as=\"saved\" hint-placeholder-count=\"2\">\n              <div style=\"background:#fdfaf5;border-radius:12px;padding:13px 16px;display:flex;align-items:center;gap:12px;border:1px solid #e8ddd0;box-shadow:0 1px 3px rgba(44,31,14,.05)\">\n                <div style=\"flex:1\">\n                  <div style=\"font-size:14px;font-weight:800;color:#2c1f0e\">{{ saved.title }}<\u002Fdiv>\n              