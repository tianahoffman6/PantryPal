-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Nunito';\n  font-style: normal;\n  font-weight: 900;\n  font-display: swap;\n  src: url(\"59e1e135-4777-4bb7-97cc-7da43f32a880\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n*{box-sizing:border-box}\nbody{margin:0;background:#f2ede4;font-family:'Nunito',system-ui,sans-serif;color:#2c1f0e}\ninput,select,button,textarea{font-family:inherit}\nbutton:focus,input:focus,select:focus{outline:none}\ninput::placeholder,textarea::placeholder{color:#b09a82}\nselect option{background:#fdfaf5;color:#2c1f0e}\n@keyframes spin{to{transform:rotate(360deg)}}\n@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}\ninput[type=date]::-webkit-calendar-picker-indicator{opacity:.4;cursor:pointer}\n::-webkit-scrollbar{width:4px;height:4px}\n::-webkit-scrollbar-thumb{background:#d4c8b8;border-radius:2px}\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<div style=\"{{ rootStyle }}\">\n\n  <!-- HEADER -->\n  <div style=\"background:#111810;height:56px;padding:0 22px;display:flex;align-items:center;position:sticky;top:0;z-index:200;border-bottom:1px solid #2a3828\">\n    <div style=\"font-family:'Bitter',Georgia,serif;font-size:22px;font-weight:700;color:#f0e8d8;letter-spacing:-.01em\">pantry<span style=\"color:#3a6e32\">pal<\u002Fspan><\u002Fdiv>\n    <div style=\"margin-left:auto;display:flex;align-items:center;gap:12px\">\n      <span style=\"font-size:12px;color:#9fbaa9\">Tiana &amp; Baltej<\u002Fspan>\n      <div style=\"display:flex\">\n        <div style=\"width:28px;height:28px;border-radius:50%;background:#4a7c3e;border:2px solid #111810;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff\">T<\u002Fdiv>\n        <div style=\"width:28px;height:28px;border-radius:50%;background:#c4693a;border:2px solid #111810;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff;margin-left:-7px\">B<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- PILL TAB BAR -->\n  <div style=\"{{ tabBarContainerStyle }}\">\n    <button style=\"{{ tabKitchenStyle }}\" onclick=\"{{ tabKitchen }}\">🍳 Kitchen<\u002Fbutton>\n    <button style=\"{{ tabGroceryStyle }}\" onclick=\"{{ tabGrocery }}\">🛒 Grocery<\u002Fbutton>\n    <button style=\"{{ tabRecipesStyle }}\" onclick=\"{{ tabRecipes }}\">✦ Recipes<\u002Fbutton>\n    <button style=\"{{ tabPlannerStyle }}\" onclick=\"{{ tabPlanner }}\">🗓 Planner<\u002Fbutton>\n    <button style=\"{{ tabSettingsStyle }}\" onclick=\"{{ tabSettings }}\">⚙ Settings<\u002Fbutton>\n  <\u002Fdiv>\n\n  <!-- ALERT STRIP -->\n  <sc-if value=\"{{ showAlerts }}\" hint-placeholder-val=\"{{ true }}\">\n    <div style=\"background:#fef8f0;border-bottom:1px solid #e8d8b8;padding:9px 22px;display:flex;flex-wrap:wrap;gap:12px;align-items:center\">\n      <sc-if value=\"{{ hasExpiring }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"display:flex;align-items:center;gap:8px;flex-wrap:wrap\">\n          <span style=\"background:#3a6e32;color:#fff;padding:3px 10px;border-radius:14px;font-weight:800;font-size:11px;white-space:nowrap\">⏰ USE SOON<\u002Fspan>\n          <span style=\"font-size:13px;color:#7a5f44\">{{ expiringStr }}<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ hasLowStock }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"display:flex;align-items:center;gap:8px;flex-wrap:wrap\">\n          <span style=\"background:#ede0c8;color:#7a5c1a;padding:3px 10px;border-radius:14px;font-weight:800;font-size:11px;white-space:nowrap;border:1px solid #e0d0b0\">📉 LOW STOCK<\u002Fspan>\n          <span style=\"font-size:13px;color:#7a5f44\">{{ lowStockStr }}<\u002Fspan>\n          <button onclick=\"{{ addLowToGrocery }}\" style=\"font-size:12px;color:#3a6e32;font-weight:800;background:none;border:none;cursor:pointer;padding:0;white-space:nowrap\">→ Add to grocery<\u002Fbutton>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- MAIN -->\n  <div style=\"max-width:1080px;margin:0 auto;padding:22px 20px 90px\">\n\n    <!-- ===== KITCHEN ===== -->\n    <sc-if value=\"{{ isKitchen }}\" hint-placeholder-val=\"{{ true }}\">\n\n      <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap\">\n        <div style=\"flex:1;min-width:200px;display:flex;align-items:center;gap:9px;background:#fdfaf5;border:1px solid #e8ddd0;border-radius:14px;padding:10px 14px\">\n          <span style=\"color:#b09a82;font-size:15px\">🔍<\u002Fspan>\n          <input placeholder=\"Search kitchen…\" value=\"{{ kitchenSearch }}\" onchange=\"{{ onKitchenSearch }}\" style=\"flex:1;border:none;background:transparent;font-size:14px;color:#2c1f0e;font-weight:600\">\n        <\u002Fdiv>\n        <button onclick=\"{{ openAddItem }}\" style=\"background:#3a6e32;color:#fff;border:none;border-radius:14px;padding:10px 18px;font-size:13.5px;font-weight:800;cursor:pointer;white-space:nowrap\">+ Add item<\u002Fbutton>\n      <\u002Fdiv>\n\n      <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:18px;flex-wrap:wrap\">\n        <div style=\"display:flex;gap:5px;background:#fdfaf5;border-radius:12px;padding:4px;box-shadow:0 1px 3px rgba(44,31,14,.07)\">\n          <button style=\"{{ locAllStyle }}\" onclick=\"{{ setLocAll }}\">All<\u002Fbutton>\n          <button style=\"{{ locFridgeStyle }}\" onclick=\"{{ setLocFridge }}\">🥶 Fridge<\u002Fbutton>\n          <button style=\"{{ locFreezerStyle }}\" onclick=\"{{ setLocFreezer }}\">❄️ Freezer<\u002Fbutton>\n          <button style=\"{{ locPantryStyle }}\" onclick=\"{{ setLocPantry }}\">🏺 Pantry<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-left:auto;display:flex;gap:8px\">\n          <select value=\"{{ kitchenCatFilter }}\" onchange=\"{{ onKitchenCatFilter }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 12px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <sc-for list=\"{{ catFilterOptions }}\" as=\"opt\" hint-placeholder-count=\"5\">\n              <option value=\"{{ opt.value }}\">{{ opt.label }}<\u002Foption>\n            <\u002Fsc-for>\n          <\u002Fselect>\n          <select value=\"{{ kitchenExpiryFilter }}\" onchange=\"{{ onKitchenExpiryFilter }}\" style=\"border:1px solid #e8ddd0;border-radius:10px;padding:8px 12px;font-size:13px;background:#fdfaf5;cursor:pointer;color:#5a4030;font-weight:600\">\n            <option value=\"all\">All items<\u002Foption>\n            <option value=\"expiring\">Expiring soon<\u002Foption>\n            <option value=\"low\">Running low<\u002Foption>\n          <\u002Fselect>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <sc-if value=\"{{ hasKitchenItems }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"display:flex;flex-direction:column;gap:12px\">\n          <sc-for list=\"{{ kitchenGroups }}\" as=\"group\" hint-placeholder-count=\"4\">\n            <div style=\"background:#fdfaf5;border-radius:16px;overflow:hidden;box-shadow:0 1px 4px rgba(44,31,14,.06);border:1px solid #e8ddd0\">\n              <div style=\"{{ group.headerStyle }}\">\n                <span style=\"font-size:17px\">{{ group.emoji }}<\u002Fspan>\n                <span style=\"{{ group.labelStyle }}\">{{ group.category }}<\u002Fspan>\n                <span style=\"font-size:11.5px;color:#b09a82;margin-left:auto\">{{ group.itemCount }}<\u002Fspan>\n              <\u002Fdiv>\n              <sc-for list=\"{{ group.items }}\" as=\"item\" hint-placeholder-count=\"3\">\n                <div style=\"{{ item.rowStyle }}\">\n                  <span style=\"{{ item.dotStyle }}\"><\u002Fspan>\n                  <span style=\"{{ item.nameStyle }}\">{{ item.name }}<\u002Fspan>\n                  <sc-if value=\"{{ item.showLoc }}\" hint-placeholder-val=\"{{ false }}\">\n                    <span style=\"{{ item.locStyle }}\">{{ item.locLabel }}<\u002Fspan>\n                  <\u002Fsc-if>\n                  <sc-if value=\"{{ item.showExpiry }}\" hint-placeholder-val=\"{{ false }}\">\n                    <span style=\"{{ item.expiryStyle }}\">{{ item.expiryText }}<\u002Fspan>\n                  <\u002Fsc-if>\n                  <sc-if value=\"{{ item.low }}\" hint-placeholder-val=\"{{ false }}\">\n                    <span style=\"font-size:10.5px;padding:2px 7px;border-radius:10px;background:#f0e8dc;color:#7a5f44;font-weight:700;border:1px solid #e0d0b0\">low<\u002Fspan>\n                  <\u002Fsc-if>\n                  <span style=\"font-size:12.5px;color:#b09a82;white-space:nowrap\">{{ item.qty }}<\u002Fspan>\n                  <button onclick=\"{{ item.del }}\" style=\"font-size:16px;background:none;border:none;cursor:pointer;color:#d4c4b0;padding:0 2px;line-height:1;flex-shrink:0\">×<\u002Fbutton>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ noKitchenItems }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"text-align:center;padding:60px 20px;color:#b09a82\">\n          <div style=\"font-size:40px;margin-bottom:12px\">🌿<\u002Fdiv>\n          <div style=\"font-size:15px;font-weight:700\">Nothing found<\u002Fdiv>\n          <div style=\"font-size:13px;margin-top:4px\">Adjust your filters or add items<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <button onclick=\"{{ openAddItem }}\" style=\"position:fixed;bottom:28px;right:28px;z-index:150;width:54px;height:54px;border-radius:50%;background:#3a6e32;border:none;color:#fff;font-size:28px;cursor:pointer;box-shadow:0 4px 20px rgba(58,110,50,