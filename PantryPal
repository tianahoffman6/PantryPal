und:s.groceryView===v?'#2c1f0e':'transparent',\n      color:s.groceryView===v?'#e8d5b8':'#7a6e60',\n    });\n\n    // ── Kitchen ──\n    const filteredItems = s.items.filter(item=>{\n      if (s.kitchenLocation!=='all'&&item.location!==s.kitchenLocation) return false;\n      if (s.kitchenCatFilter!=='all'&&item.category!==s.kitchenCatFilter) return false;\n      if (s.kitchenExpiryFilter==='expiring'&&!(item.daysLeft!==null&&item.daysLeft<=3)) return false;\n      if (s.kitchenExpiryFilter==='low'&&!item.low) return false;\n      if (s.kitchenSearch&&!item.name.toLowerCase().includes(s.kitchenSearch.toLowerCase())) return false;\n      return true;\n    });\n    const catMap = {};\n    filteredItems.forEach(item=>{\n      if (!catMap[item.category]) catMap[item.category]=[];\n      catMap[item.category].push(this.enrichKitchenItem(item,cats,s.kitchenLocation==='all'));\n    });\n    const kitchenGroups = Object.keys(catMap).map(catName=>{\n      const c = this.getCat(catName,cats);\n      return {\n        category:catName, emoji:c.emoji, itemCount:catMap[catName].length,\n        headerStyle:{display:'flex',alignItems:'center',gap:'9px',padding:'12px 16px',background:c.bg,borderBottom:'1px solid '+c.dot+'30'},\n        labelStyle:{fontSize:'13px',fontWeight:800,color:c.color},\n        items:catMap[catName],\n      };\n    });\n    const expiring = s.items.filter(i=>i.daysLeft!==null&&i.daysLeft<=3);\n    const lowStock  = s.items.filter(i=>i.low);\n    const catFilterOptions = [{value:'all',label:'All categories'},...cats.map(c=>({value:c.name,label:c.emoji+' '+c.name}))];\n\n    // ── Grocery ──\n    const filteredGrocery = s.groceryItems.filter(item=>{\n      if (s.groceryStoreFilter!=='all'&&item.store!==s.groceryStoreFilter) return false;\n      if (!s.groceryShowChecked&&item.checked) return false;\n      if (s.grocerySearch&&!item.name.toLowerCase().includes(s.grocerySearch.toLowerCase())) return false;\n      return true;\n    });\n    const enrichedGrocery