e=\"display:flex;flex-direction:column;gap:10px;margin-bottom:20px\">\n        <sc-for list=\"{{ plannerDays }}\" as=\"day\" hint-placeholder-count=\"7\">\n          <div style=\"{{ day.cardStyle }}\">\n            <div style=\"{{ day.headerStyle }}\">\n              <span style=\"{{ day.dayLabelStyle }}\">{{ day.label }}<\u002Fspan>\n              <span style=\"{{ day.dateStyle }}\">{{ day.dateStr }}<\u002Fspan>\n              <sc-if value=\"{{ day.isToday }}\" hint-placeholder-val=\"{{ false }}\">\n                <span style=\"font-size:10px;font-weight:800;background:#3a6e32;color:#fff;padding:2px 8px;border-radius:10px;margin-left:6px\">TODAY<\u002Fspan>\n              <\u002Fsc-if>\n            <\u002Fdiv>\n            <div style=\"display:flex;gap:8px;padding:10px 14px;flex-wrap:wrap\">\n              <sc-for list=\"{{ day.slots }}\" as=\"slot\" hint-placeholder-count=\"3\">\n                <div ondragover=\"{{ slot.dragOver }}\" ondrop=\"{{ slot.drop }}\" style=\"{{ slot.slotStyle }}\">\n                  <div style=\"{{ slot.mealTagStyle }}\">{{ slot.mealIcon }} {{ slot.meal }}<\u002Fdiv>\n                  <sc-if value=\"{{ slot.assigned }}\" hint-placeholder-val=\"{{ false }}\">\n                    <div style=\"display:flex;align-items:flex-start;gap:4px;margin-top:4px\">\n                      <div style=\"flex:1;min-width:0\">\n                        <div onclick=\"{{ slot.openRecipe }}\" style=\"font-size:12px;font-weight:700;color:#2c1f0e;cursor:pointer;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap\">{{ slot.recipeName }}<\u002Fdiv>\n                        <div style=\"font-size:10.5px;color:#b09a82;margin-top:2px\">{{ slot.recipeTime }}<\u002Fdiv>\n                      <\u002Fdiv>\n                      <button onclick=\"{{ slot.remove }}\" style=\"font-size:14px;background:none;border:none;cursor:pointer;color:#d4c4b0;padding:0;line-height:1;flex-shrink:0\">×<\u002Fbutton>\n                    <\u002Fdiv>\n                  <\u002Fsc-if>\n                  <sc-if value=\"{{ slot.empty }}\" hint-placeholder-val=\"{{ true }}\">\n                    <button onclick=\"{{ slot.openPicker }}\" style=\"margin-top:5px;font-size:11px;font-weight:700;color:#b09a82;background:none;border:1px dashed #d8d0c4;border-radius:8px;padding:4px 8px;cursor:pointer;width:100%\">+ Add<\u002Fbutton>\n                  <\u002Fsc-if>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n      <div style=\"background:#fdfaf5;border-radius:18px;padding:18px;border:1px solid #e8ddd0\">\n        <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap\">\n          <div style=\"font-family:'Bitter',Georgia,serif;font-size:16px;font-weight:700;color:#2c1f0e;flex:1\">Recipe Browser<\u002Fdiv>\n          <div style=\"display:flex;align-items:center;gap:8px;background:#f4ede2;border-radius:10px;padding:7px 12px;min-width:150px\">\n            <span style=\"color:#b09a82;font-size:13px\">🔍<\u002Fspan>\n            <input placeholder=\"Search…\" value=\"{{ plannerSearch }}\" onchange=\"{{ onPlannerSearch }}\" style=\"border:none;background:transparent;font-size:13px;color:#2c1f0e;font-weight:600;flex:1;min-width:0\">\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"display:flex;gap:5px;flex-wrap:wrap;margin-bottom:12px\">\n          <sc-for list=\"{{ plannerMealChips }}\" as=\"chip\" hint-placeholder-count=\"5\">\n            <button style=\"{{ chip.style }}\" onclick=\"{{ chip.handler }}\">{{ chip.label }}<\u002Fbutton>\n          <\u002Fsc-for>\n        <\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px\">\n          <sc-for list=\"{{ plannerRecipes }}\" as=\"r\" hint-placeholder-count=\"6\">\n            <div draggable=\"true\" ondragstart=\"{{ r.dragStart }}\" ondragend=\"{{ r.dragEnd }}\" style=\"{{ r.cardStyle }}\">\n              